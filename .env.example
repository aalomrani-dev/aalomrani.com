# Knowledge Platform — environment template.
# Copy this file to `.env` (which is gitignored) and fill in your values:
#     cp .env.example .env
#
# Find both in the Supabase dashboard → Project Settings → API.
# Use the PUBLISHABLE key (sb_publishable_…), NOT the secret key — it's safe for
# the browser because every table is guarded by RLS and document binaries are
# only ever served as short-lived signed URLs to active members.
#
# These same two vars must also be set in the Vercel project (Settings → Environment Variables).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
